# Canada Life AI Governance Command Centre
# Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git — it's in .gitignore.
# In Lovable: add these as Secrets in the project settings.
# ─────────────────────────────────────────────────────────────

# Anthropic API Key
# Get yours at: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Project URL
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Supabase Anon (Public) Key
# Found in: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
